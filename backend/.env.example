# VexoCrm/backend/.env.example
# Copy to .env and fill with real values.
# For EasyPanel: add these vars in the app's Environment section.

# Server
NODE_ENV=production
PORT=3001
CORS_ORIGINS=https://vexocrm.vercel.app
GROQ_API_KEY=gsk_xxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# Webhooks (Bearer token for Authorization header)
LEADS_WEBHOOK_SECRET=your-secret-here
N8N_WEBHOOK_SECRET=your-secret-here

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
